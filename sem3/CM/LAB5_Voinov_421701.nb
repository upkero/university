Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Euler", "[", 
    RowBox[{
    "f1_", ",", "f2_", ",", "a_", ",", "b_", ",", "y0_", ",", "z0_", ",", 
     "h_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "y", ",", "z", ",", "x", ",", "i"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"n", "=", 
       FractionBox[
        RowBox[{"b", "-", "a"}], "h"]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Array", "[", 
       RowBox[{"y", ",", "0", ",", "n"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "=", "y0"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Array", "[", 
       RowBox[{"z", ",", "0", ",", "n"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"z", "[", "0", "]"}], "=", "z0"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"x", "[", "i_", "]"}], ":=", 
       RowBox[{"a", "+", 
        RowBox[{"i", " ", "h"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "0"}], ",", 
        RowBox[{"i", "<", "n"}], ",", 
        RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "[", 
           RowBox[{"i", "+", "1"}], "]"}], "=", 
          RowBox[{
           RowBox[{"y", "[", "i", "]"}], "+", 
           RowBox[{"h", " ", 
            RowBox[{"f1", "[", 
             RowBox[{
              RowBox[{"x", "[", "i", "]"}], ",", 
              RowBox[{"y", "[", "i", "]"}], ",", 
              RowBox[{"z", "[", "i", "]"}]}], "]"}]}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"z", "[", 
           RowBox[{"i", "+", "1"}], "]"}], "=", 
          RowBox[{
           RowBox[{"z", "[", "i", "]"}], "+", 
           RowBox[{"h", " ", 
            RowBox[{"f2", "[", 
             RowBox[{
              RowBox[{"x", "[", "i", "]"}], ",", 
              RowBox[{"y", "[", "i", "]"}], ",", 
              RowBox[{"z", "[", "i", "]"}]}], "]"}]}]}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "[", "i", "]"}], ",", 
            RowBox[{"y", "[", "i", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", 
            RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "[", "i", "]"}], ",", 
            RowBox[{"z", "[", "i", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", 
            RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], "}"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
