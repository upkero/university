Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Task2", "[", 
    RowBox[{"f1_", ",", "f2_", ",", "y0_", ",", "z0_", ",", "h_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "t1", ",", "t2", ",", "t3", ",", "t4", ",", "t5", ",", "gr1", ",", 
       "gr2", ",", "gr3", ",", "gr4", ",", "y", ",", "z"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"t1", "=", 
       RowBox[{"Euler", "[", 
        RowBox[{
        "f1", ",", "f2", ",", "a", ",", "b", ",", "y0", ",", "z0", ",", "h"}],
         "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"t2", "=", 
       RowBox[{"RungeKutta4Sys2", "[", 
        RowBox[{
        "f1", ",", "f2", ",", "a", ",", "b", ",", "y0", ",", "z0", ",", "h"}],
         "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"t3", "=", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
            RowBox[{"f1", "[", 
             RowBox[{"x", ",", 
              RowBox[{"y", "[", "x", "]"}], ",", 
              RowBox[{"z", "[", "x", "]"}]}], "]"}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"z", "'"}], "[", "x", "]"}], "==", 
            RowBox[{"f2", "[", 
             RowBox[{"x", ",", 
              RowBox[{"y", "[", "x", "]"}], ",", 
              RowBox[{"z", "[", "x", "]"}]}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"y", "[", "0", "]"}], "==", "y0"}], ",", 
           RowBox[{
            RowBox[{"z", "[", "0", "]"}], "==", "z0"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"y", "[", "x", "]"}], ",", 
           RowBox[{"z", "[", "x", "]"}]}], "}"}], ",", "x"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t4", ",", "t5"}], "}"}], "=", 
       RowBox[{"NDSolveValue", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
            RowBox[{"f1", "[", 
             RowBox[{"x", ",", 
              RowBox[{"y", "[", "x", "]"}], ",", 
              RowBox[{"z", "[", "x", "]"}]}], "]"}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"z", "'"}], "[", "x", "]"}], "==", 
            RowBox[{"f2", "[", 
             RowBox[{"x", ",", 
              RowBox[{"y", "[", "x", "]"}], ",", 
              RowBox[{"z", "[", "x", "]"}]}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"y", "[", "0", "]"}], "==", "y0"}], ",", 
           RowBox[{
            RowBox[{"z", "[", "0", "]"}], "==", "z0"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", "z"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr1", "=", 
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"t1", ",", " ", 
         RowBox[{"ImageSize", "->", "Large"}], ",", " ", 
         RowBox[{"PlotStyle", "->", "Red"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr2", "=", 
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"t2", ",", " ", 
         RowBox[{"ImageSize", "->", "Large"}], ",", " ", 
         RowBox[{"PlotStyle", "->", "Green"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr3", "=", 
       RowBox[{"Plot", "[", 
        RowBox[{"t3", ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", " ", 
         RowBox[{"ImageSize", "->", "Large"}], ",", " ", 
         RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr4", "=", 
