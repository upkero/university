Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"EulerCouchy", "[", 
    RowBox[{"f_", ",", "a_", ",", "b_", ",", "y0_", ",", "h_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "xs", ",", "ys", ",", "i", ",", "predictor"}], "}"}], 
     ",", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Round", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"b", "-", "a"}], ")"}], "/", "h"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"xs", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"a", "+", 
          RowBox[{"i", " ", "h"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ys", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0.", ",", 
         RowBox[{"n", "+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ys", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "=", "y0"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", "n"}], ",", 
        RowBox[{"i", "++"}], ",", 
        RowBox[{
         RowBox[{"predictor", "=", 
          RowBox[{
           RowBox[{"ys", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "+", 
           RowBox[{"h", " ", 
            RowBox[{"f", "[", 
             RowBox[{
              RowBox[{"xs", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", 
              RowBox[{"ys", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ys", "[", 
           RowBox[{"[", 
            RowBox[{"i", "+", "1"}], "]"}], "]"}], "=", 
          RowBox[{
           RowBox[{"ys", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "+", 
           RowBox[{
            RowBox[{"h", "/", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"f", "[", 
               RowBox[{
                RowBox[{"xs", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], ",", 
                RowBox[{"ys", "[", 
                 RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "+", 
              RowBox[{"f", "[", 
               RowBox[{
                RowBox[{"xs", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", "predictor"}], 
               "]"}]}], ")"}]}]}]}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"xs", ",", "ys"}], "}"}], "]"}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9111384904323583`*^9, 3.9111385983901095`*^9}, {
