Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Task1", "[", 
    RowBox[{"f_", ",", "y0_", ",", "h_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "t1", ",", "t2", ",", "solN", ",", "gr1", ",", "gr2", ",", "gr3"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"t1", "=", 
       RowBox[{"EulerCouchy", "[", 
        RowBox[{"f", ",", "a", ",", "b", ",", "y0", ",", "h"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"t2", "=", 
       RowBox[{"RungeKutta4", "[", 
        RowBox[{"f", ",", "a", ",", "b", ",", "y0", ",", "h"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"solN", "=", 
       RowBox[{"NDSolveValue", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
            RowBox[{"f", "[", 
             RowBox[{"x", ",", 
              RowBox[{"y", "[", "x", "]"}]}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"y", "[", "a", "]"}], "==", "y0"}]}], "}"}], ",", "y", ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr1", "=", 
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"t1", ",", 
         RowBox[{"ImageSize", "->", "Large"}], ",", 
         RowBox[{"PlotStyle", "->", "Red"}], ",", 
         RowBox[{"PlotLegends", "->", 
          RowBox[{"{", "\"\<Euler-Cauchy\>\"", "}"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr2", "=", 
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"t2", ",", 
         RowBox[{"ImageSize", "->", "Large"}], ",", 
         RowBox[{"PlotStyle", "->", "Green"}], ",", 
         RowBox[{"PlotLegends", "->", 
          RowBox[{"{", "\"\<Runge-Kutta 4\>\"", "}"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"gr3", "=", 
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{"solN", "[", "x", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
         RowBox[{"ImageSize", "->", "Large"}], ",", 
         RowBox[{"PlotStyle", "->", "Black"}], ",", 
         RowBox[{"PlotLegends", "->", 
          RowBox[{"{", "\"\<NDSolve\>\"", "}"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"gr1", ",", "gr2", ",", "gr3"}], "}"}]}]}], "]"}]}], 
  ";"}]], "Input",
