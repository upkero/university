Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "x", "]"}], ";", 
   RowBox[{
    RowBox[{"h", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"4", "*", 
      RowBox[{"3", "^", 
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}]}]}], "-", 
     RowBox[{"2", "x"}], "+", 
     RowBox[{"15", 
