Cell[CellGroupData[{

Cell["\:0431) \:041c\:0435\:0442\:043e\:0434 \:0441\:0435\:043a\:0443\:0449\
\:0438\:0445 (\:0447\:0438\:0441\:043b\:043e \:0438\:0442\:0435\:0440\:0430\
\:0446\:0438\:0439)", "Subsection",
 CellChangeTimes->{
  3.97196405350211*^9},ExpressionUUID->"c33a83f0-a2a6-4b7f-9e5d-aa1a044b2723"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"secant", "[", 
     RowBox[{"f_", ",", "x0_", ",", "x1_", ",", 
      RowBox[{"eps_", ":", "1.*^-3"}], ",", 
      RowBox[{"maxIter_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "=", "x0"}], ",", 
        RowBox[{"b", "=", "x1"}], ",", 
        RowBox[{"fa", "=", 
         RowBox[{"f", "[", "x0", "]"}]}], ",", 
        RowBox[{"fb", "=", 
         RowBox[{"f", "[", "x1", "]"}]}], ",", "c", ",", "fc", ",", 
        RowBox[{"it", "=", "0"}], ",", 
        RowBox[{"tr", "=", 
         RowBox[{"{", 
          RowBox[{"x0", ",", "x1"}], "}"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"it", "<", "maxIter"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"c", "=", 
           RowBox[{"b", "-", 
            RowBox[{"fb", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"b", "-", "a"}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"fb", "-", "fa"}], ")"}]}]}]}]}], ";", 
          RowBox[{"fc", "=", 
           RowBox[{"f", "[", "c", "]"}]}], ";", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"tr", ",", "c"}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", "fc", "]"}], "<", "eps"}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<root\>\"", "->", "c"}], ",", 
               RowBox[{"\"\<iters\>\"", "->", 
                RowBox[{"it", "+", "1"}]}], ",", 
               RowBox[{"\"\<trace\>\"", "->", "tr"}]}], "|>"}], "]"}]}], 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"a", "=", "b"}], ";", 
          RowBox[{"fa", "=", "fb"}], ";", 
          RowBox[{"b", "=", "c"}], ";", 
          RowBox[{"fb", "=", "fc"}], ";", 
          RowBox[{"it", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<root\>\"", "->", "c"}], ",", 
         RowBox[{"\"\<iters\>\"", "->", "it"}], ",", 
         RowBox[{"\"\<trace\>\"", "->", "tr"}], ",", 
         RowBox[{"\"\<note\>\"", "->", "\"\<maxIter\>\""}]}], "|>"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"resS", "=", 
   RowBox[{"secant", "[", 
    RowBox[{"h", ",", "0.5", ",", "2.0", ",", 
     RowBox[{"10.", "^", 
      RowBox[{"-", "3"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<[\:0421\:0435\:043a\:0443\:0449\:0438\:0435] \:043a\:043e\
\:0440\:0435\:043d\:044c \[TildeTilde] \>\"", ",", 
    RowBox[{"N", "@", 
     RowBox[{"resS", "[", "\"\<root\>\"", "]"}]}], 
    ",", "\"\<, \:0438\:0442\:0435\:0440\:0430\:0446\:0438\:0439 = \>\"", ",", 
    RowBox[{"resS", "[", "\"\<iters\>\"", "]"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{
