Cell[CellGroupData[{

Cell["\:0430) \:0413\:0440\:0430\:0444\:0438\:043a\:0430 + \:043c\:0435\:0442\
\:043e\:0434 \:041d\:044c\:044e\:0442\:043e\:043d\:0430 (\:0447\:0438\:0441\
\:043b\:043e \:0438\:0442\:0435\:0440\:0430\:0446\:0438\:0439)", \
"Subsubsection",
 CellChangeTimes->{
  3.9719638866329203`*^9},ExpressionUUID->"2f58e0a5-abb4-4477-a2fd-\
1c52efa601b5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"h", ",", "x"}], "]"}], ";", 
   RowBox[{
    RowBox[{"h", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"4", "*", 
      RowBox[{"3", "^", 
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}]}]}], "-", 
     RowBox[{"2", "x"}], "+", 
     RowBox[{"15", 
      RowBox[{"x", "^", "2"}]}], "-", "37"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"h", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"10", "^", 
       RowBox[{"-", "3"}]}], ",", "8"}], "}"}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<\:0417\:0430\:0434\:0430\:043d\:0438\:0435 3.9: h(x) = \
4*3^(1-x)-2x+15x^2-37\>\""}], ",", "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<h(x)\>\""}], "}"}]}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}]}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"newton", "[", 
     RowBox[{"f_", ",", "x0_", ",", 
      RowBox[{"eps_", ":", "1.*^-3"}], ",", 
      RowBox[{"maxIter_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "=", "x0"}], ",", 
        RowBox[{"it", "=", "0"}], ",", 
        RowBox[{"tr", "=", 
         RowBox[{"{", "x", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"it", "<", "maxIter"}], ",", 
         RowBox[{
          RowBox[{"x", "=", 
           RowBox[{"x", "-", 
            RowBox[{
             RowBox[{"f", "[", "x", "]"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{"f", "[", "\[Xi]", "]"}], ",", "\[Xi]"}], "]"}], "/.",
                " ", 
               RowBox[{"\[Xi]", "->", "x"}]}], ")"}]}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"tr", ",", "x"}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"f", "[", "x", "]"}], "]"}], "<", "eps"}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<root\>\"", "->", "x"}], ",", 
               RowBox[{"\"\<iters\>\"", "->", 
                RowBox[{"it", "+", "1"}]}], ",", 
               RowBox[{"\"\<trace\>\"", "->", "tr"}]}], "|>"}], "]"}]}], 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"it", "++"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<root\>\"", "->", "x"}], ",", 
         RowBox[{"\"\<iters\>\"", "->", "it"}], ",", 
         RowBox[{"\"\<trace\>\"", "->", "tr"}], ",", 
         RowBox[{"\"\<note\>\"", "->", "\"\<maxIter\>\""}]}], "|>"}]}]}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"resN", "=", 
   RowBox[{"newton", "[", 
    RowBox[{"h", ",", "1.0", ",", 
     RowBox[{"10.", "^", 
      RowBox[{"-", "3"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<[\:041d\:044c\:044e\:0442\:043e\:043d] \:043a\:043e\:0440\
\:0435\:043d\:044c \[TildeTilde] \>\"", ",", 
    RowBox[{"N", "@", 
     RowBox[{"resN", "[", "\"\<root\>\"", "]"}]}], 
    ",", "\"\<, \:0438\:0442\:0435\:0440\:0430\:0446\:0438\:0439 = \>\"", ",", 
    RowBox[{"resN", "[", "\"\<iters\>\"", "]"}]}], "]"}], ";"}]}], "Input",
