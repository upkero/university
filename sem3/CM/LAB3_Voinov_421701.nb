Cell["\:0431) \:0418\:0442\:0435\:0440\:0430\:0446\:0438\:0438 x_{k+1}=g(x_k) \
(\:0447\:0438\:0441\:043b\:043e \:0438\:0442\:0435\:0440\:0430\:0446\:0438\
\:0439)", "Subsubsection",
 CellChangeTimes->{
  3.971964287784602*^9},ExpressionUUID->"f2e61152-e38f-4146-94a8-\
bc39d3e2e9ac"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fixedPoint", "[", 
     RowBox[{"g_", ",", "x0_", ",", 
      RowBox[{"eps_", ":", "1.*^-3"}], ",", 
      RowBox[{"maxIter_", ":", "200"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "=", "x0"}], ",", "x1", ",", 
        RowBox[{"it", "=", "0"}], ",", 
        RowBox[{"tr", "=", 
         RowBox[{"{", "x0", "}"}]}]}], "}"}], ",", 
      RowBox[{
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"it", "<", "maxIter"}], ",", 
         RowBox[{
          RowBox[{"x1", "=", 
           RowBox[{"g", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"!", 
              RowBox[{"NumericQ", "[", "x1", "]"}]}], "||", 
             RowBox[{"!", 
              RowBox[{"FiniteQ", "[", "x1", "]"}]}]}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<note\>\"", "->", "\"\<overflow\>\""}], ",", 
               RowBox[{"\"\<iters\>\"", "->", "it"}], ",", 
               RowBox[{"\"\<trace\>\"", "->", "tr"}]}], "|>"}], "]"}]}], 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"tr", ",", "x1"}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"x1", "-", "x"}], "]"}], "<", "eps"}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<root\>\"", "->", "x1"}], ",", 
               RowBox[{"\"\<iters\>\"", "->", 
                RowBox[{"it", "+", "1"}]}], ",", 
               RowBox[{"\"\<trace\>\"", "->", "tr"}]}], "|>"}], "]"}]}], 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"x", "=", "x1"}], ";", 
          RowBox[{"it", "++"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<note\>\"", "->", "\"\<maxIter\>\""}], ",", 
         RowBox[{"\"\<iters\>\"", "->", "it"}], ",", 
         RowBox[{"\"\<trace\>\"", "->", "tr"}]}], "|>"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n"}], "\n", 
 RowBox[{
  RowBox[{"resPI", "=", 
   RowBox[{"fixedPoint", "[", 
    RowBox[{"g", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"A", "+", "B"}], ")"}], "/", "2"}], ",", 
     RowBox[{"10.", "^", 
      RowBox[{"-", "3"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<[\:041f\:0440\:043e\:0441\:0442\:044b\:0435 \
\:0438\:0442\:0435\:0440\:0430\:0446\:0438\:0438] \:043a\:043e\:0440\:0435\
\:043d\:044c \[TildeTilde] \>\"", ",", 
    RowBox[{"N", "@", 
     RowBox[{"resPI", "[", "\"\<root\>\"", "]"}]}], 
    ",", "\"\<, \:0438\:0442\:0435\:0440\:0430\:0446\:0438\:0439 = \>\"", ",", 
    RowBox[{"resPI", "[", "\"\<iters\>\"", "]"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.971964295980974*^9, 3.9719643177896833`*^9}, {
