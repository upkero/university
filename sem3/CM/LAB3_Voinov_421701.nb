    RowBox[{"Quiet", "@", 
     RowBox[{"NSolve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"h", "[", "x", "]"}], "==", "0"}], ",", "x", ",", "Reals"}], 
      "]"}]}]}], "]"}], ";"}], "\n", 
 RowBox[{
