Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"f6", ",", "g6", ",", "x", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"f6", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}], "-", 
       RowBox[{"6", "y"}]}], ")"}], "^", "2"}], "-", 
    RowBox[{"36", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}], ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"g6", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Surd", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", "-", "4"}], ")"}], "^", "2"}], ",", "3"}], "]"}], "+", 
     RowBox[{"Surd", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"y", "-", "1"}], ")"}], "^", "2"}], ",", "3"}], "]"}], "-", 
     "4"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
