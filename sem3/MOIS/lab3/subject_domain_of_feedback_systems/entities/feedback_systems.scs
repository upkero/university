////////////////////////////////////////////////////////////////////////////////
// СИСТЕМЫ ОБРАТНОЙ СВЯЗИ
////////////////////////////////////////////////////////////////////////////////

// --- системы ---

room_temperature_control_system
<- concept_feedback_system;
=> nrel_main_idtf:
[система регулирования температуры помещения]
(* <- lang_ru;; *);
=> nrel_feedback_type:
concept_negative_feedback;;

cruise_control_system
<- concept_feedback_system;
=> nrel_main_idtf:
[система круиз-контроля автомобиля]
(* <- lang_ru;; *);
=> nrel_feedback_type:
concept_negative_feedback;;

audio_agc_system
<- concept_feedback_system;
=> nrel_main_idtf:
[система автоматической регулировки усиления]
(* <- lang_ru;; *);
=> nrel_feedback_type:
concept_negative_feedback;;


////////////////////////////////////////////////////////////////////////////////
// ЭЛЕМЕНТЫ КОНТУРА: СИСТЕМА РЕГУЛИРОВАНИЯ ТЕМПЕРАТУРЫ ПОМЕЩЕНИЯ
////////////////////////////////////////////////////////////////////////////////

room_controller
<- concept_control_loop_element;
=> nrel_main_idtf:
[регулятор температуры помещения]
(* <- lang_ru;; *);

room_plant
<- concept_control_loop_element;
=> nrel_main_idtf:
[помещение как объект управления]
(* <- lang_ru;; *);

room_sensor
<- concept_control_loop_element;
=> nrel_main_idtf:
[датчик температуры помещения]
(* <- lang_ru;; *);

room_feedback_path
<- concept_control_loop_element;
=> nrel_main_idtf:
[контур обратной связи системы регулирования температуры помещения]
(* <- lang_ru;; *);

// связи "состоит из"
room_temperature_control_system
=> nrel_consists_of:
room_controller;
room_plant;
room_sensor;
room_feedback_path;;

// ролевые связи
room_temperature_control_system
-> rrel_controller: room_controller;;
room_temperature_control_system
-> rrel_plant: room_plant;;
room_temperature_control_system
-> rrel_sensor: room_sensor;;
room_temperature_control_system
-> rrel_feedback_path: room_feedback_path;;


