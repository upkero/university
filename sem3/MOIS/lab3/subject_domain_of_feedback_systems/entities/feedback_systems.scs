////////////////////////////////////////////////////////////////////////////////
// ЭЛЕМЕНТЫ КОНТУРА: СИСТЕМА АВТОМАТИЧЕСКОЙ РЕГУЛИРОВКИ УСИЛЕНИЯ
////////////////////////////////////////////////////////////////////////////////

agc_controller
<- concept_control_loop_element;
=> nrel_main_idtf:
[регулятор уровня усиления]
(* <- lang_ru;; *);

agc_plant
<- concept_control_loop_element;
=> nrel_main_idtf:
[усилитель как объект управления]
(* <- lang_ru;; *);

agc_sensor
<- concept_control_loop_element;
=> nrel_main_idtf:
[датчик уровня сигнала]
(* <- lang_ru;; *);

agc_feedback_path
<- concept_control_loop_element;
=> nrel_main_idtf:
[контур обратной связи системы автоматической регулировки усиления]
(* <- lang_ru;; *);

// связи "состоит из"
audio_agc_system
