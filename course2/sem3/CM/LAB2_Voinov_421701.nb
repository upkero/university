Cell[CellGroupData[{

Cell["\:0436) \:041f\:043e\:0432\:0442\:043e\:0440\:0438\:0442\:044c \:043f\
\:0443\:043d\:043a\:0442\:044b \:0430\[Dash]\:0435 \:0434\:043b\:044f \
(n=10).", "Subsection",
 CellChangeTimes->{{3.971940356947915*^9, 
  3.9719403715129766`*^9}},ExpressionUUID->"7a066141-dd7d-475d-8326-\
8ad92f6fec2f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"data10", "=", 
    RowBox[{"eqData", "[", "n", "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ln10", "[", "x_", "]"}], "=", 
   RowBox[{
    RowBox[{"eqPoly", "[", "n", "]"}], "//", "Simplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Pn10", "[", "x_", "]"}], "=", 
   RowBox[{"Ln10", "[", "x", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Np10", "[", "x_", "]"}], "=", 
    RowBox[{
     RowBox[{"InterpolatingPolynomial", "[", 
      RowBox[{"data10", ",", "x"}], "]"}], "//", "Simplify"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], ",", 
        RowBox[{"Pn10", "[", "x", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<f(x)\>\"", ",", "\"\<P10(x)\>\""}], "}"}]}], ",", 
      RowBox[{"ImageSize", "->", "img"}]}], "]"}], ",", 
    RowBox[{"pts", "[", "data10", "]"}]}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "x0", "]"}], ",", 
     RowBox[{"Ln10", "[", "x0", "]"}], ",", 
     RowBox[{"Pn10", "[", "x0", "]"}], ",", 
     RowBox[{"Np10", "[", "x0", "]"}]}], "}"}], "//", "N"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Rn10", "[", "x_", "]"}], "=", 
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], "-", 
     RowBox[{"Np10", "[", "x", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Rn10", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<|R10(x)|\>\""}], ",", 
   RowBox[{"ImageSize", "->", "img"}]}], "]"}], "\n", 
 RowBox[{"maxRn10", "=", 
  RowBox[{"maxErr", "[", 
   RowBox[{"Rn10", "[", "x", "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{3.971940382867219*^9},
 CellLabel->
  "In[160]:=",ExpressionUUID->"c73ce253-4942-4b52-b2de-7617d971a86b"],

