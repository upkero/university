           RowBox[{"b", "-", "a"}], ")"}], "/", "n"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"eqData", "[", "n_Integer", "]"}], ":=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"xs", "=", 
         RowBox[{"eqGrid", "[", "n", "]"}]}], "}"}], ",", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"xs", ",", 
          RowBox[{"N", "@", 
           RowBox[{"(", 
            RowBox[{"f", "/@", "xs"}], ")"}]}]}], "}"}], "]"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"n", "=", "5"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"data5", "=", 
     RowBox[{"eqData", "[", "n", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Sf5", "=", 
     RowBox[{"Interpolation", "[", 
      RowBox[{"data5", ",", 
       RowBox[{"Method", "->", "\"\<Spline\>\""}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"img", "=", "800"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"f", "[", "x", "]"}], ",", 
         RowBox[{"Sf5", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<f(x)\>\"", ",", "\"\<S5(x)\>\""}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ImageSize", "->", "img"}]}], "]"}], ",", 
     RowBox[{"ListPlot", "[", 
      RowBox[{"data5", ",", 
       RowBox[{"PlotStyle", "->", "Black"}], ",", 
       RowBox[{"PlotMarkers", "->", "Automatic"}]}], "]"}]}], "]"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"R5s", "[", "x_", "]"}], ":=", 
     RowBox[{"Abs", "[", 
      RowBox[{
       RowBox[{"f", "[", "x", "]"}], "-", 
       RowBox[{"Sf5", "[", "x", "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"R5s", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<|f - S5|\>\""}], ",", 
     RowBox[{"ImageSize", "->", "img"}]}], "]"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "\:0411\:0435\:0437\:043e\:043f\:0430\:0441\:043d\:044b\:0439", " ", 
     "\:043c\:0430\:043a\:0441\:0438\:043c\:0443\:043c"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"maxErr", "[", 
      RowBox[{"expr_", ",", 
       RowBox[{"{", 
        RowBox[{"xl_", ",", "xr_"}], "}"}]}], "]"}], ":=", 
     RowBox[{"Quiet", "@", 
      RowBox[{"Check", "[", 
       RowBox[{
        RowBox[{"FindMaximum", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"expr", ",", 
            RowBox[{"xl", "<=", "x", "<=", "xr"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"xl", "+", "xr"}], ")"}], "/", "2"}]}], "}"}]}], "]"}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"With", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"xs", "=", 
            RowBox[{"Subdivide", "[", 
             RowBox[{"xl", ",", "xr", ",", "800"}], "]"}]}], "}"}], ",", 
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"vals", "=", 
               RowBox[{"Abs", "[", 
                RowBox[{"expr", "/.", " ", 
                 RowBox[{"x", "->", "xs"}]}], "]"}]}], ",", "i"}], "}"}], ",", 
            RowBox[{
             RowBox[{"i", "=", 
              RowBox[{
               RowBox[{"Ordering", "[", 
                RowBox[{"vals", ",", 
                 RowBox[{"-", "1"}]}], "]"}], "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"vals", "[", 
                RowBox[{"[", "i", "]"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"x", "->", 
                 RowBox[{"xs", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], "}"}]}]}], 
           "]"}]}], "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"maxR5s", "=", 
    RowBox[{"maxErr", "[", 
     RowBox[{
      RowBox[{"R5s", "[", "x", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b"}], "}"}]}], "]"}]}]}]}]], "Input",
