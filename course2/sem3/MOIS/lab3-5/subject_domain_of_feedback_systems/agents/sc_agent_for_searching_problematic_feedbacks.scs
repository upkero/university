sc_agent_for_searching_problematic_feedbacks
=> nrel_main_idtf:
    [sc-агент поиска проблемных обращений]
    (*
        <- lang_ru;;
    *);
=> nrel_main_idtf:
    [sc-agent for searching problematic feedbacks]
    (*
        <- lang_en;;
    *);
<- abstract_sc_agent;

// агент активируется на событие создания выходящей дуги из action_initiated
=> nrel_primary_initiation_condition:
    (sc_event_after_generate_outgoing_arc => action_initiated);

=> nrel_sc_agent_action_class:
    action_search_problematic_feedbacks;

=> nrel_initiation_condition_and_result:
    (sc_agent_for_searching_problematic_feedbacks_condition
     => sc_agent_for_searching_problematic_feedbacks_result);

<= nrel_sc_agent_key_sc_elements:
{
    action_initiated;
    action_search_problematic_feedbacks
};

// реализация как платформенно-независимый агент (SCP)
=> nrel_inclusion: sc_agent_for_searching_problematic_feedbacks_implementation
(*
    <- platform_independent_abstract_sc_agent;;

    <= nrel_sc_agent_program:
    {
        agent_program_for_searching_problematic_feedbacks;
        program_for_searching_problematic_feedbacks
    };;

    -> scp_agent_for_searching_problematic_feedbacks
    (*
        <- active_sc_agent;;
    *);;
*);;

// полное условие инициирования: действие нужного класса и оно инициировано
sc_agent_for_searching_problematic_feedbacks_condition = [*
    action_search_problematic_feedbacks _-> .._action;;
    action_initiated _-> .._action;;
*];;

// условие результата: у действия появился nrel_result со множеством feedback
sc_agent_for_searching_problematic_feedbacks_result = [*
    concept_feedback _-> .._feedback;;
*];;
