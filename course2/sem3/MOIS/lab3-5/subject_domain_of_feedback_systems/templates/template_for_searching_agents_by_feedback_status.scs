@search_agents_by_feedback_status_template = {
    rrel_init_template: {
        rrel_template: [*
            @input_param1 = (.._status <-_ concept_status);;
            nrel_status _-> (.._feedback _=> .._status);;
            @output_param1 = (.._feedback <-_ concept_feedback);;
        *];
        rrel_template_input_params: { @input_param1 };
        rrel_template_output_params: { @output_param1 }
    } (* <- nrel_search_set_template;; *);

    rrel_next_template: {
        rrel_init_template: {
            rrel_template: [*
                @input_param1 = (.._feedback <-_ concept_feedback);;
                rrel_agent _-> (.._agent <-_ .._feedback);;
                @output_param1 = (.._agent <-_ concept_support_agent);;
            *];
            rrel_template_input_params: { @input_param1 };
            rrel_template_output_params: { @output_param1 }
        } (* <- nrel_search_set_template;; *)
    } (* <- nrel_fixed_search_strategy_template;; *)
};;

@search_agents_by_feedback_status_template
<- nrel_fixed_search_strategy_template;
=> nrel_main_idtf: [Шаблон поиска операторов по статусу обратной связи](* <- lang_ru;; *);
=> nrel_main_idtf: [Template for searching agents by feedback status](* <- lang_en;; *);;
